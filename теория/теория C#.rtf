\u1047\'c7\u1072\'e0\u1084\'ec\u1099\'fb\u1082\'ea\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5, \u1080\'e8\u1083\'eb\u1080\'e8 closure \u8212\'97 \u1101\'fd\u1090\'f2\u1086\'ee \u1084\'ec\u1077\'e5\u1093\'f5\u1072\'e0\u1085\'ed\u1080\'e8\u1079\'e7\u1084\'ec, \u1087\'ef\u1088\'f0\u1080\'e8 \u1082\'ea\u1086\'ee\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1084\'ec \u1083\'eb\u1103\'ff\u1084\'ec\u1073\'e1\u1076\'e4\u1072\'e0-\u1074\'e2\u1099\'fb\u1088\'f0\u1072\'e0\u1078\'e6\u1077\'e5\u1085\'ed\u1080\'e8\u1077\'e5 \u171\'ab\u1079\'e7\u1072\'e0\u1093\'f5\u1074\'e2\u1072\'e0\u1090\'f2\u1099\'fb\u1074\'e2\u1072\'e0\u1077\'e5\u1090\'f2\u187\'bb \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1084\'ec\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1077\'e5 \u1080\'e8\u1079\'e7 \u1074\'e2\u1085\'ed\u1077\'e5\u1096\'f8\u1085\'ed\u1077\'e5\u1075\'e3\u1086\'ee \u1082\'ea\u1086\'ee\u1085\'ed\u1090\'f2\u1077\'e5\u1082\'ea\u1089\'f1\u1090\'f2\u1072\'e0 \u1080\'e8 \u1087\'ef\u1088\'f0\u1086\'ee\u1076\'e4\u1086\'ee\u1083\'eb\u1078\'e6\u1072\'e0\u1077\'e5\u1090\'f2 \u1080\'e8\u1084\'ec\u1077\'e5\u1090\'f2\u1100\'fc \u1082\'ea \u1085\'ed\u1080\'e8\u1084\'ec \u1076\'e4\u1086\'ee\u1089\'f1\u1090\'f2\u1091\'f3\u1087\'ef \u1076\'e4\u1072\'e0\u1078\'e6\u1077\'e5 \u1087\'ef\u1086\'ee\u1089\'f1\u1083\'eb\u1077\'e5 \u1074\'e2\u1099\'fb\u1093\'f5\u1086\'ee\u1076\'e4\u1072\'e0 \u1080\'e8\u1079\'e7 \u1086\'ee\u1073\'e1\u1083\'eb\u1072\'e0\u1089\'f1\u1090\'f2\u1080\'e8 \u1074\'e2\u1080\'e8\u1076\'e4\u1080\'e8\u1084\'ec\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8, \u1074\'e2 \u1082\'ea\u1086\'ee\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1081\'e9 \u1086\'ee\u1085\'ed\u1080\'e8 \u1073\'e1\u1099\'fb\u1083\'eb\u1080\'e8 \u1086\'ee\u1073\'e1\u1098\'fa\u1103\'ff\u1074\'e2\u1083\'eb\u1077\'e5\u1085\'ed\u1099\'fb.}
{\cf1\f7\par}\pard\plain \s20\sl276\slmult1\sb0\sa140\ql\widctlpar\sb0\sa240\ltrpar{\cf1\f7
\u1055\'cf\u1088\'f0\u1080\'e8\u1084\'ec\u1077\'e5\u1088\'f0: \u1089\'f1\u1086\'ee\u1079\'e7\u1076\'e4\u1072\'e0\u1105\'b8\u1090\'f2\u1089\'f1\u1103\'ff \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1084\'ec\u1077\'e5\u1085\'ed\u1085\'ed\u1072\'e0\u1103\'ff \u1074\'e2\u1085\'ed\u1077\'e5 \u1083\'eb\u1103\'ff\u1084\'ec\u1073\'e1\u1076\'e4\u1099\'fb, \u1079\'e7\u1072\'e0\u1090\'f2\u1077\'e5\u1084\'ec \u1074\'e2\u1085\'ed\u1091\'f3\u1090\'f2\u1088\'f0\u1080\'e8 \u1083\'eb\u1103\'ff\u1084\'ec\u1073\'e1\u1076\'e4\u1099\'fb \u1086\'ee\u1085\'ed\u1072\'e0 \u1080\'e8\u1089\'f1\u1087\'ef\u1086\'ee\u1083\'eb\u1100\'fc\u1079\'e7\u1091\'f3\u1077\'e5\u1090\'f2\u1089\'f1\u1103\'ff \u1080\'e8 \u1080\'e8\u1079\'e7\u1084\'ec\u1077\'e5\u1085\'ed\u1103\'ff\u1077\'e5\u1090\'f2\u1089\'f1\u1103\'ff. \u1044\'c4\u1072\'e0\u1078\'e6\u1077\'e5 \u1087\'ef\u1086\'ee\u1089\'f1\u1083\'eb\u1077\'e5 \u1079\'e7\u1072\'e0\u1074\'e2\u1077\'e5\u1088\'f0\u1096\'f8\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1074\'e2\u1085\'ed\u1077\'e5\u1096\'f8\u1085\'ed\u1077\'e5\u1075\'e3\u1086\'ee \u1084\'ec\u1077\'e5\u1090\'f2\u1086\'ee\u1076\'e4\u1072\'e0 \u1083\'eb\u1103\'ff\u1084\'ec\u1073\'e1\u1076\'e4\u1072\'e0 \u1089\'f1\u1086\'ee\u1093\'f5\u1088\'f0\u1072\'e0\u1085\'ed\u1103\'ff\u1077\'e5\u1090\'f2 \u1076\'e4\u1086\'ee\u1089\'f1\u1090\'f2\u1091\'f3\u1087\'ef \u1082\'ea \u1101\'fd\u1090\'f2\u1086\'ee\u1081\'e9 \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1084\'ec\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee\u1081\'e9.}
{\cf1\f7\par}\pard\plain \s20\sl276\slmult1\sb0\sa140\ql\widctlpar\sb0\sa240\ltrpar{\cf1\f7
\u1052\'cc\u1077\'e5\u1093\'f5\u1072\'e0\u1085\'ed\u1080\'e8\u1079\'e7\u1084\'ec \u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1072\'e0\u1077\'e5\u1090\'f2 \u1090\'f2\u1072\'e0\u1082\'ea: \u1082\'ea\u1086\'ee\u1084\'ec\u1087\'ef\u1080\'e8\u1083\'eb\u1103\'ff\u1090\'f2\u1086\'ee\u1088\'f0 \u1089\'f1\u1086\'ee\u1079\'e7\u1076\'e4\u1072\'e0\u1105\'b8\u1090\'f2 \u1089\'f1\u1087\'ef\u1077\'e5\u1094\'f6\u1080\'e8\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1081\'e9 \u1089\'f1\u1082\'ea\u1088\'f0\u1099\'fb\u1090\'f2\u1099\'fb\u1081\'e9 \u1086\'ee\u1073\'e1\u1098\'fa\u1077\'e5\u1082\'ea\u1090\'f2, \u1074\'e2 \u1082\'ea\u1086\'ee\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1084\'ec \u1093\'f5\u1088\'f0\u1072\'e0\u1085\'ed\u1103\'ff\u1090\'f2\u1089\'f1\u1103\'ff \u1079\'e7\u1072\'e0\u1093\'f5\u1074\'e2\u1072\'e0\u1095\'f7\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1077\'e5 \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1084\'ec\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1077\'e5. \u1051\'cb\u1103\'ff\u1084\'ec\u1073\'e1\u1076\'e4\u1072\'e0 \u1092\'f4\u1072\'e0\u1082\'ea\u1090\'f2\u1080\'e8\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1080\'e8 \u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1072\'e0\u1077\'e5\u1090\'f2 \u1089\'f1 \u1101\'fd\u1090\'f2\u1080\'e8\u1084\'ec \u1086\'ee\u1073\'e1\u1098\'fa\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1084\'ec, \u1072\'e0 \u1085\'ed\u1077\'e5 \u1089\'f1 \u1080\'e8\u1089\'f1\u1093\'f5\u1086\'ee\u1076\'e4\u1085\'ed\u1086\'ee\u1081\'e9 \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1084\'ec\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee\u1081\'e9 \u1085\'ed\u1072\'e0\u1087\'ef\u1088\'f0\u1103\'ff\u1084\'ec\u1091\'f3\u1102\'fe. \u1041\'c1\u1083\'eb\u1072\'e0\u1075\'e3\u1086\'ee\u1076\'e4\u1072\'e0\u1088\'f0\u1103\'ff \u1101\'fd\u1090\'f2\u1086\'ee\u1084\'ec\u1091\'f3 \u1079\'e7\u1085\'ed\u1072\'e0\u1095\'f7\u1077\'e5\u1085\'ed\u1080\'e8\u1077\'e5 \u1089\'f1\u1086\'ee\u1093\'f5\u1088\'f0\u1072\'e0\u1085\'ed\u1103\'ff\u1077\'e5\u1090\'f2\u1089\'f1\u1103\'ff \u1084\'ec\u1077\'e5\u1078\'e6\u1076\'e4\u1091\'f3 \u1074\'e2\u1099\'fb\u1079\'e7\u1086\'ee\u1074\'e2\u1072\'e0\u1084\'ec\u1080\'e8.}
{\cf1\f7\par}\pard\plain \s20\sl276\slmult1\sb0\sa140\ql\widctlpar\sb0\sa240\ltrpar{\cf1\f7
\u1058\'d2\u1072\'e0\u1082\'ea\u1080\'e8\u1084\'ec \u1086\'ee\u1073\'e1\u1088\'f0\u1072\'e0\u1079\'e7\u1086\'ee\u1084\'ec, \u1072\'e0\u1085\'ed\u1086\'ee\u1085\'ed\u1080\'e8\u1084\'ec\u1085\'ed\u1099\'fb\u1077\'e5 \u1084\'ec\u1077\'e5\u1090\'f2\u1086\'ee\u1076\'e4\u1099\'fb \u1080\'e8 \u1083\'eb\u1103\'ff\u1084\'ec\u1073\'e1\u1076\'e4\u1072\'e0-\u1074\'e2\u1099\'fb\u1088\'f0\u1072\'e0\u1078\'e6\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff \u1087\'ef\u1086\'ee\u1079\'e7\u1074\'e2\u1086\'ee\u1083\'eb\u1103\'ff\u1102\'fe\u1090\'f2 \u1089\'f1\u1086\'ee\u1079\'e7\u1076\'e4\u1072\'e0\u1074\'e2\u1072\'e0\u1090\'f2\u1100\'fc \u1092\'f4\u1091\'f3\u1085\'ed\u1082\'ea\u1094\'f6\u1080\'e8\u1080\'e8 \u171\'ab\u1085\'ed\u1072\'e0 \u1084\'ec\u1077\'e5\u1089\'f1\u1090\'f2\u1077\'e5\u187\'bb, \u1076\'e4\u1077\'e5\u1083\'eb\u1077\'e5\u1075\'e3\u1072\'e0\u1090\'f2\u1099\'fb \u1086\'ee\u1073\'e1\u1077\'e5\u1089\'f1\u1087\'ef\u1077\'e5\u1095\'f7\u1080\'e8\u1074\'e2\u1072\'e0\u1102\'fe\u1090\'f2 \u1080\'e8\u1093\'f5 \u1080\'e8\u1089\'f1\u1087\'ef\u1086\'ee\u1083\'eb\u1100\'fc\u1079\'e7\u1086\'ee\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5, \u1072\'e0 \u1079\'e7\u1072\'e0\u1084\'ec\u1099\'fb\u1082\'ea\u1072\'e0\u1085\'ed\u1080\'e8\u1103\'ff \u1076\'e4\u1072\'e0\u1102\'fe\u1090\'f2 \u1074\'e2\u1086\'ee\u1079\'e7\u1084\'ec\u1086\'ee\u1078\'e6\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1100\'fc \u1088\'f0\u1072\'e0\u1073\'e1\u1086\'ee\u1090\'f2\u1072\'e0\u1090\'f2\u1100\'fc \u1089\'f1 \u1074\'e2\u1085\'ed\u1077\'e5\u1096\'f8\u1085\'ed\u1080\'e8\u1084\'ec\u1080\'e8 \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1084\'ec\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1084\'ec\u1080\'e8 \u1080\'e8 \u1089\'f1\u1086\'ee\u1093\'f5\u1088\'f0\u1072\'e0\u1085\'ed\u1103\'ff\u1090\'f2\u1100\'fc \u1080\'e8\u1093\'f5 \u1089\'f1\u1086\'ee\u1089\'f1\u1090\'f2\u1086\'ee\u1103\'ff\u1085\'ed\u1080\'e8\u1077\'e5.}
